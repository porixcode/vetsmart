# ─── PostgreSQL ───
POSTGRES_USER=vetsmart
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=vetsmart
POSTGRES_HOST_PORT=5432

# DATABASE_URL para uso LOCAL (bun dev con postgres corriendo en docker).
# Dentro del network de compose, el servicio `app` recibe un DATABASE_URL
# con host `postgres` (ver override en docker-compose.yml).
DATABASE_URL=postgresql://vetsmart:change_me_in_production@localhost:5432/vetsmart

# ─── Auth.js v5 ───
# Genera uno nuevo con: openssl rand -base64 32
NEXTAUTH_SECRET=replace_me_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ─── App ───
APP_HOST_PORT=3000
TZ=America/Bogota
