out/
build/
dist/
*.tsbuildinfo
.turbo/

# =========================
# 🔐 Variables de Entorno
# =========================
.env
.env.local
.env.development
.env.test
.env.production
.env*.local
# Consejo: `.env*.local` ya cubre `.env.development.local`, `.env.production.local`, etc.

# =========================
# 🗄️ Base de Datos & ORM (Prisma)
# =========================
prisma/*.db
prisma/*.db-journal
prisma/migrations/dev/
# Nota: `prisma/dev.db` se eliminó porque ya está cubierto por `prisma/*.db`

